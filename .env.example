# Neon PostgreSQL (JDBC format)
DATABASE_URL=jdbc:postgresql://YOUR_HOST.neon.tech/neondb?sslmode=require
DATABASE_USERNAME=your_neon_user
DATABASE_PASSWORD=your_neon_password

# Comma-separated allowed frontend origins (add your Render/Vercel URL in production)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Render sets PORT automatically — only needed for local runs
PORT=8080
